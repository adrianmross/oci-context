import Cocoa
import UserNotifications

final class AppDelegate: NSObject, NSApplicationDelegate, UNUserNotificationCenterDelegate {
    private let categoryIdentifier = "OCI_AUTH"
    private let reauthActionIdentifier = "OCI_REAUTH"
    private var profile = "DEFAULT"
    private var region = ""
    private var contextName = "current"
    private var reason = "Authentication required"
    private var tenancyName = ""

    func applicationDidFinishLaunching(_ notification: Notification) {
        parseArgs(CommandLine.arguments)

        let center = UNUserNotificationCenter.current()
        center.delegate = self
        let reauthAction = UNNotificationAction(
            identifier: reauthActionIdentifier,
            title: "Re-auth now",
            options: [.foreground]
        )
        let category = UNNotificationCategory(
            identifier: categoryIdentifier,
            actions: [reauthAction],
            intentIdentifiers: [],
            options: []
        )
        center.setNotificationCategories([category])

        center.requestAuthorization(options: [.alert, .sound]) { granted, error in
            if granted {
                self.deliverAuthNotification()
                DispatchQueue.main.async {
                    self.presentAuthPrompt()
                }
            } else {
                if let error = error {
                    NSLog("OCI Access notification authorization failed: \(error)")
                }
                DispatchQueue.main.async {
                    self.presentAuthPrompt()
                }
            }
        }
    }

    func userNotificationCenter(
        _ center: UNUserNotificationCenter,
        willPresent notification: UNNotification,
        withCompletionHandler completionHandler: @escaping (UNNotificationPresentationOptions) -> Void
    ) {
        completionHandler([.banner, .sound])
    }

    func userNotificationCenter(
        _ center: UNUserNotificationCenter,
        didReceive response: UNNotificationResponse,
        withCompletionHandler completionHandler: @escaping () -> Void
    ) {
        if shouldRunAuthentication(response.actionIdentifier) {
            runAuthentication()
        }
        completionHandler()
        NSApp.terminate(nil)
    }

    private func shouldRunAuthentication(_ actionIdentifier: String) -> Bool {
        return actionIdentifier == reauthActionIdentifier ||
            actionIdentifier == UNNotificationDefaultActionIdentifier
    }

    private func deliverAuthNotification() {
        let content = UNMutableNotificationContent()
        content.title = "OCI Access Required"
        content.subtitle = contextName
        content.body = "Auth unhealthy for \(contextName) (\(profile))\n\(reason)"
        content.sound = .default
        content.categoryIdentifier = categoryIdentifier

        let request = UNNotificationRequest(
            identifier: "oci-context-auth-\(contextName)",
            content: content,
            trigger: nil
        )
        UNUserNotificationCenter.current().add(request) { error in
            if let error = error {
                NSLog("OCI Access notification delivery failed: \(error)")
                DispatchQueue.main.async {
                    NSApp.terminate(nil)
                }
            }
        }
    }

    private func presentAuthPrompt() {
        NSApp.activate(ignoringOtherApps: true)
        let alert = NSAlert()
        alert.messageText = "OCI Access Required"
        alert.informativeText = "Auth unhealthy for \(contextName) (\(profile))\n\(reason)"
        alert.alertStyle = .warning
        alert.addButton(withTitle: "Re-auth now")
        alert.addButton(withTitle: "Dismiss")
        let response = alert.runModal()
        if response == .alertFirstButtonReturn {
            runAuthentication()
        }
        NSApp.terminate(nil)
    }

    private func parseArgs(_ args: [String]) {
        var index = 1
        while index < args.count {
            let key = args[index]
            let value = index + 1 < args.count ? args[index + 1] : ""
            switch key {
            case "--profile":
                profile = value.isEmpty ? "DEFAULT" : value
                index += 2
            case "--region":
                region = value
                index += 2
            case "--context":
                contextName = value.isEmpty ? "current" : value
                index += 2
            case "--reason":
                reason = value.isEmpty ? "Authentication required" : value
                index += 2
            case "--tenancy-name":
                tenancyName = value
                index += 2
            default:
                index += 1
            }
        }
    }

    private func runAuthentication() {
        let task = Process()
        let ociPath = resolveOCIPath()
        task.executableURL = URL(fileURLWithPath: ociPath ?? "/usr/bin/env")
        var args = ociPath == nil ? ["oci", "session", "authenticate", "--profile-name", profile] : ["session", "authenticate", "--profile-name", profile]
        if !region.isEmpty {
            args += ["--region", region]
        }
        if !tenancyName.isEmpty {
            args += ["--tenancy-name", tenancyName]
        }
        task.arguments = args
        try? task.run()
    }

    private func resolveOCIPath() -> String? {
        for path in ["/opt/homebrew/bin/oci", "/usr/local/bin/oci", "/usr/bin/oci"] {
            if FileManager.default.isExecutableFile(atPath: path) {
                return path
            }
        }
        return nil
    }
}

let app = NSApplication.shared
let delegate = AppDelegate()
app.delegate = delegate
app.run()
